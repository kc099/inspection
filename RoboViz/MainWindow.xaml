<Window x:Class="RoboViz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoboViz"
        mc:Ignorable="d"
        Title="RoboViz - Washer Inspection System" Height="920" Width="1600"
        Background="#FF111114" Loaded="Window_Loaded">

    <Window.Resources>
        <FontFamily x:Key="Orbitron">pack://application:,,,/Fonts/#Orbitron</FontFamily>
        <FontFamily x:Key="ShareTechMono">pack://application:,,,/Fonts/#Share Tech Mono</FontFamily>
        <FontFamily x:Key="Montserrat">pack://application:,,,/Fonts/#Montserrat</FontFamily>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource Montserrat}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModelToggle" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="{StaticResource Montserrat}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF8E8E96"/>
            <Setter Property="Background" Value="#FF252530"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FF353540"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1565C0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF42A5F5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImageFrame" TargetType="Border">
            <Setter Property="Background" Value="#FF18181E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#FF2A2A34"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar spanning full width -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="WASHER DEFECT DETECTION"
                       FontFamily="{StaticResource Orbitron}" FontSize="24" FontWeight="Bold"
                       Foreground="#FF42A5F5" HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="DateTimeText" Text=""
                       FontFamily="{StaticResource ShareTechMono}" FontSize="15"
                       FontWeight="Bold" Foreground="#FFE0E0E6" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65*"/>
                <ColumnDefinition Width="35*" MinWidth="480"/>
            </Grid.ColumnDefinitions>

            <!-- Left: 2x2 Image Grid -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="BottomCamRow" Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ImageFrame}">
                    <Grid>
                        <Image x:Name="ImageDisplay0" Stretch="Uniform" Margin="6"/>
                    <TextBlock x:Name="CamLabel0" Text="CAM 1 [MaskRCNN]" FontFamily="{StaticResource Montserrat}"
                                   FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                        <TextBlock x:Name="VerdictLabel0" Text=""
                                   FontFamily="{StaticResource Orbitron}"
                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                                   Padding="6,2"/>
                    </Grid>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ImageFrame}">
                    <Grid>
                        <Image x:Name="ImageDisplay1" Stretch="Uniform" Margin="6"/>
                    <TextBlock x:Name="CamLabel1" Text="CAM 2 [MaskRCNN]" FontFamily="{StaticResource Montserrat}"
                                   FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                        <TextBlock x:Name="VerdictLabel1" Text=""
                                   FontFamily="{StaticResource Orbitron}"
                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                                   Padding="6,2"/>
                    </Grid>
                </Border>

                <Border x:Name="CamBorder2" Grid.Row="1" Grid.Column="0" Style="{StaticResource ImageFrame}">
                    <Grid>
                        <Image x:Name="ImageDisplay2" Stretch="Uniform" Margin="6"/>
                    <TextBlock x:Name="CamLabel2" Text="CAM 3 [PatchCore]" FontFamily="{StaticResource Montserrat}"
                                   FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                        <TextBlock x:Name="VerdictLabel2" Text=""
                                   FontFamily="{StaticResource Orbitron}"
                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                                   Padding="6,2"/>
                    </Grid>
                </Border>

                <Border x:Name="CamBorder3" Grid.Row="1" Grid.Column="1" Style="{StaticResource ImageFrame}">
                    <Grid>
                        <Image x:Name="ImageDisplay3" Stretch="Uniform" Margin="6"/>
                    <TextBlock x:Name="CamLabel3" Text="CAM 4 [PatchCore]" FontFamily="{StaticResource Montserrat}"
                                   FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                        <TextBlock x:Name="VerdictLabel3" Text=""
                                   FontFamily="{StaticResource Orbitron}"
                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                                   Padding="6,2"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock x:Name="StatusText" Text="Model: loading..."
                               FontFamily="{StaticResource Montserrat}" FontSize="15"
                               Foreground="#FFC8C8CD" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Button Grid.Column="0" Content="Load Image" Height="50"
                                Click="LoadImage_Click" Background="#FF2E7D32"
                                Style="{StaticResource ActionButton}" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" x:Name="BtnStream" Content="Start Stream" Height="50"
                                Click="Stream_Click" Background="#FF6A1B9A"
                                Style="{StaticResource ActionButton}" Margin="5,0,5,0"/>
                        <Button Grid.Column="2" x:Name="BtnAnalyze" Content="Analyze" Height="50"
                                Click="Analyze_Click" Background="#FF1565C0"
                                Style="{StaticResource ActionButton}" IsEnabled="False" Margin="5,0,0,0"/>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                            <CheckBox x:Name="ChkShowOverlay"
                                      Content="Show Overlay" IsChecked="False"
                                      Foreground="#FFC8C8CD" FontFamily="{StaticResource Montserrat}"
                                      FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="CAMERAS" FontFamily="{StaticResource Montserrat}"
                                       FontSize="11" FontWeight="Bold" Foreground="#FF6E6E76"
                                       VerticalAlignment="Center" Margin="24,0,8,0"/>
                            <ToggleButton x:Name="Btn2Cam" Style="{StaticResource ModelToggle}"
                                          Width="70" Height="30" Checked="Cam2_Click">
                                <TextBlock Text="2 CAM" FontFamily="{StaticResource Montserrat}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </ToggleButton>
                            <ToggleButton x:Name="Btn4Cam" Style="{StaticResource ModelToggle}"
                                          IsChecked="True" Width="70" Height="30" Margin="6,0,0,0"
                                          Checked="Cam4_Click">
                                <TextBlock Text="4 CAM" FontFamily="{StaticResource Montserrat}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>

                    <!-- Model Selection -->
                    <Border Background="#FF1C1C24" CornerRadius="8"
                            BorderBrush="#FF2A2A34" BorderThickness="1" Padding="10,8"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="MODEL" FontFamily="{StaticResource Montserrat}"
                                       FontSize="11" FontWeight="Bold" Foreground="#FF6E6E76"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <ToggleButton x:Name="BtnModel1"
                                          Style="{StaticResource ModelToggle}"
                                          Checked="Model1_Click" Margin="0,0,10,0"
                                          Width="180" Height="100">
                                <StackPanel>
                                    <Image Source="Assets/model1.png" Height="60" Stretch="Uniform" Margin="0,2,0,4"/>
                                    <TextBlock Text="Model 1" HorizontalAlignment="Center"
                                               FontFamily="{StaticResource Montserrat}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnModel2" IsChecked="True"
                                          Style="{StaticResource ModelToggle}"
                                          Checked="Model2_Click" Margin="0,0,0,0"
                                          Width="180" Height="100">
                                <StackPanel>
                                    <Image Source="Assets/model2.png" Height="60" Stretch="Uniform" Margin="0,2,0,4"/>
                                    <TextBlock Text="Model 2" HorizontalAlignment="Center"
                                               FontFamily="{StaticResource Montserrat}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- Detector Assignment Per Row -->
                    <Border Background="#FF1C1C24" CornerRadius="8"
                            BorderBrush="#FF2A2A34" BorderThickness="1" Padding="10,8"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="DETECTOR ASSIGNMENT" FontFamily="{StaticResource Montserrat}"
                                       FontSize="11" FontWeight="Bold" Foreground="#FF6E6E76"
                                       Margin="0,0,0,8"/>
                            <!-- Row 1 (CAM 1 & CAM 2) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="ROW 1 (CAM 1-2)" FontFamily="{StaticResource Montserrat}"
                                           FontSize="11" Foreground="#FF42A5F5"
                                           VerticalAlignment="Center" Width="120"/>
                                <ToggleButton x:Name="BtnRow1MaskRCNN" IsChecked="True"
                                              Style="{StaticResource ModelToggle}"
                                              Width="100" Height="30" Checked="Row1MaskRCNN_Click">
                                    <TextBlock Text="MaskRCNN" FontFamily="{StaticResource Montserrat}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnRow1PatchCore"
                                              Style="{StaticResource ModelToggle}"
                                              Width="100" Height="30" Margin="6,0,0,0"
                                              Checked="Row1PatchCore_Click">
                                    <TextBlock Text="PatchCore" FontFamily="{StaticResource Montserrat}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </ToggleButton>
                            </StackPanel>
                            <!-- Row 2 (CAM 3 & CAM 4) -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ROW 2 (CAM 3-4)" FontFamily="{StaticResource Montserrat}"
                                           FontSize="11" Foreground="#FF42A5F5"
                                           VerticalAlignment="Center" Width="120"/>
                                <ToggleButton x:Name="BtnRow2MaskRCNN"
                                              Style="{StaticResource ModelToggle}"
                                              Width="100" Height="30" Checked="Row2MaskRCNN_Click">
                                    <TextBlock Text="MaskRCNN" FontFamily="{StaticResource Montserrat}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnRow2PatchCore" IsChecked="True"
                                              Style="{StaticResource ModelToggle}"
                                              Width="100" Height="30" Margin="6,0,0,0"
                                              Checked="Row2PatchCore_Click">
                                    <TextBlock Text="PatchCore" FontFamily="{StaticResource Montserrat}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Batch Verdict Banner -->
                    <Border x:Name="VerdictBorder" Height="84" CornerRadius="12"
                            Background="#FF1C1C24" Margin="0,0,0,14"
                            BorderBrush="#FF2A2A34" BorderThickness="1">
                        <TextBlock x:Name="VerdictText" Text="LOADING..."
                                   FontFamily="{StaticResource Orbitron}"
                                   Foreground="#FF6E6E76" FontSize="42" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Geometric Metrics (from CAM 1) -->
                    <Border Background="#FF18181E" CornerRadius="10" Padding="14,12" Margin="0,0,0,14"
                            BorderBrush="#FF2A2A34" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="GEOMETRIC METRICS (CAM 1)"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF6E6E76" FontSize="11" FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Metric"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Value"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="Min"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="Max"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="Status"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#FF2A2A34" Margin="0,0,0,4"/>
                            <ItemsControl x:Name="MetricsPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                       FontFamily="{StaticResource ShareTechMono}"
                                                       Foreground="#FFC8C8CD" FontSize="13"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ValueText}"
                                                       FontFamily="{StaticResource ShareTechMono}"
                                                       Foreground="{Binding ValueColor}" FontSize="13"
                                                       FontWeight="Bold"/>
                                            <TextBlock Grid.Column="2" Text="{Binding LoText}"
                                                       FontFamily="{StaticResource ShareTechMono}"
                                                       Foreground="#FF6E6E76" FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="{Binding HiText}"
                                                       FontFamily="{StaticResource ShareTechMono}"
                                                       Foreground="#FF6E6E76" FontSize="12"/>
                                            <TextBlock Grid.Column="4" Text="{Binding StatusText}"
                                                       FontFamily="{StaticResource ShareTechMono}"
                                                       Foreground="{Binding StatusColor}" FontSize="13"
                                                       FontWeight="Bold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Batch Timing -->
                    <TextBlock x:Name="CycleTimeText" Text=""
                               FontFamily="{StaticResource ShareTechMono}"
                               Foreground="#FF64B5F6" FontSize="12" Margin="0,0,0,6"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="DetailsText" Text=""
                               FontFamily="{StaticResource Montserrat}"
                               Foreground="#FF505058" FontSize="12"
                               TextWrapping="Wrap"/>

                    <!-- Modbus RS-485 Configuration -->
                    <Border Background="#FF18181E" CornerRadius="10" Padding="14,12" Margin="0,14,0,14"
                            BorderBrush="#FF2A2A34" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MODBUS RS-485 OUTPUT"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF6E6E76" FontSize="11" FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="COM Port"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF42A5F5" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <ComboBox x:Name="CmbComPort" Grid.Row="0" Grid.Column="1"
                                          FontFamily="{StaticResource ShareTechMono}" FontSize="12"
                                          Background="#FF252530" Foreground="#FFC8C8CD"
                                          Margin="0,0,16,6" MinWidth="90"
                                          DropDownOpened="CmbComPort_DropDownOpened"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Baud Rate"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF42A5F5" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <ComboBox x:Name="CmbBaudRate" Grid.Row="0" Grid.Column="3"
                                          FontFamily="{StaticResource ShareTechMono}" FontSize="12"
                                          Background="#FF252530" Foreground="#FFC8C8CD"
                                          Margin="0,0,0,6" MinWidth="90"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="4800"/>
                                    <ComboBoxItem Content="9600"/>
                                    <ComboBoxItem Content="19200"/>
                                    <ComboBoxItem Content="38400"/>
                                    <ComboBoxItem Content="57600"/>
                                    <ComboBoxItem Content="115200"/>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Slave ID"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF42A5F5" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <TextBox x:Name="TxtSlaveId" Grid.Row="1" Grid.Column="1"
                                         Text="1"
                                         FontFamily="{StaticResource ShareTechMono}" FontSize="12"
                                         Background="#FF252530" Foreground="#FFC8C8CD"
                                         BorderBrush="#FF353540" Padding="4,2"
                                         Margin="0,0,16,6"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Coil Addr"
                                           FontFamily="{StaticResource Montserrat}"
                                           Foreground="#FF42A5F5" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <TextBox x:Name="TxtCoilAddress" Grid.Row="1" Grid.Column="3"
                                         Text="0"
                                         FontFamily="{StaticResource ShareTechMono}" FontSize="12"
                                         Background="#FF252530" Foreground="#FFC8C8CD"
                                         BorderBrush="#FF353540" Padding="4,2"
                                         Margin="0,0,0,6"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button x:Name="BtnModbusConnect" Content="Connect"
                                        Width="100" Height="32"
                                        Click="ModbusConnect_Click" Background="#FF1565C0"
                                        Style="{StaticResource ActionButton}"/>
                                <Button x:Name="BtnModbusDisconnect" Content="Disconnect"
                                        Width="100" Height="32" Margin="10,0,0,0"
                                        Click="ModbusDisconnect_Click" Background="#FF616161"
                                        Style="{StaticResource ActionButton}" IsEnabled="False"/>
                                <TextBlock x:Name="ModbusStatusText" Text="Disconnected"
                                           FontFamily="{StaticResource ShareTechMono}"
                                           Foreground="#FF6E6E76" FontSize="12"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Modbus Trigger Mode -->
                    <Border Background="#FF18181E" CornerRadius="10" Padding="14,12" Margin="0,0,0,14"
                            BorderBrush="#FF2A2A34" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MODBUS TRIGGER MODE"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF6E6E76" FontSize="11" FontWeight="Bold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Reads trigger_config.json for COM, baud, slave, coil addresses."
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF505058" FontSize="10"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnTriggerStart" Content="Start Trigger"
                                        Width="120" Height="32"
                                        Click="TriggerStart_Click" Background="#FF2E7D32"
                                        Style="{StaticResource ActionButton}"/>
                                <Button x:Name="BtnTriggerStop" Content="Stop Trigger"
                                        Width="120" Height="32" Margin="10,0,0,0"
                                        Click="TriggerStop_Click" Background="#FF616161"
                                        Style="{StaticResource ActionButton}" IsEnabled="False"/>
                            </StackPanel>

                            <TextBlock x:Name="TriggerStatusText" Text="Stopped"
                                       FontFamily="{StaticResource ShareTechMono}"
                                       Foreground="#FF6E6E76" FontSize="12"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
