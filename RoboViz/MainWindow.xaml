<Window x:Class="RoboViz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoboViz"
        mc:Ignorable="d"
        Title="RoboViz - Washer Inspection System" Height="920" Width="1600"
        Background="#FF111114" Loaded="Window_Loaded">

    <Window.Resources>
        <FontFamily x:Key="Orbitron">pack://application:,,,/Fonts/#Orbitron</FontFamily>
        <FontFamily x:Key="ShareTechMono">pack://application:,,,/Fonts/#Share Tech Mono</FontFamily>
        <FontFamily x:Key="Montserrat">pack://application:,,,/Fonts/#Montserrat</FontFamily>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource Montserrat}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModelToggle" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="{StaticResource Montserrat}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF8E8E96"/>
            <Setter Property="Background" Value="#FF252530"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FF353540"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1565C0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF42A5F5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Image frame style -->
        <Style x:Key="ImageFrame" TargetType="Border">
            <Setter Property="Background" Value="#FF18181E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#FF2A2A34"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65*"/>
            <ColumnDefinition Width="35*" MinWidth="480"/>
        </Grid.ColumnDefinitions>

        <!-- Left: 2x2 Image Grid -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ImageFrame}">
                <Grid>
                    <Image x:Name="ImageDisplay0" Stretch="Uniform" Margin="6"/>
                    <TextBlock Text="CAM 1" FontFamily="{StaticResource Montserrat}"
                               FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                    <TextBlock x:Name="VerdictLabel0" Text=""
                               FontFamily="{StaticResource Orbitron}"
                               FontSize="14" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                               Padding="6,2" />
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ImageFrame}">
                <Grid>
                    <Image x:Name="ImageDisplay1" Stretch="Uniform" Margin="6"/>
                    <TextBlock Text="CAM 2" FontFamily="{StaticResource Montserrat}"
                               FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                    <TextBlock x:Name="VerdictLabel1" Text=""
                               FontFamily="{StaticResource Orbitron}"
                               FontSize="14" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                               Padding="6,2" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ImageFrame}">
                <Grid>
                    <Image x:Name="ImageDisplay2" Stretch="Uniform" Margin="6"/>
                    <TextBlock Text="CAM 3" FontFamily="{StaticResource Montserrat}"
                               FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                    <TextBlock x:Name="VerdictLabel2" Text=""
                               FontFamily="{StaticResource Orbitron}"
                               FontSize="14" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                               Padding="6,2" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ImageFrame}">
                <Grid>
                    <Image x:Name="ImageDisplay3" Stretch="Uniform" Margin="6"/>
                    <TextBlock Text="CAM 4" FontFamily="{StaticResource Montserrat}"
                               FontSize="10" FontWeight="Bold" Foreground="#FF505058"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8"/>
                    <TextBlock x:Name="VerdictLabel3" Text=""
                               FontFamily="{StaticResource Orbitron}"
                               FontSize="14" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                               Padding="6,2" />
                </Grid>
            </Border>
        </Grid>

        <!-- Right Panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="WASHER INSPECTION SYSTEM"
                           FontFamily="{StaticResource Orbitron}" FontSize="22" FontWeight="Bold"
                           Foreground="#FF42A5F5" Margin="0,0,0,4"/>

                <TextBlock x:Name="StatusText" Text="Model: loading..."
                           FontFamily="{StaticResource Montserrat}" FontSize="15"
                           Foreground="#FFC8C8CD" Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="Load Image" Width="140" Height="44"
                            Click="LoadImage_Click" Background="#FF2E7D32"
                            Style="{StaticResource ActionButton}"/>
                    <Button x:Name="BtnAnalyze" Content="Analyze" Width="140" Height="44"
                            Click="Analyze_Click" Margin="10,0,0,0" Background="#FF1565C0"
                            Style="{StaticResource ActionButton}" IsEnabled="False"/>

                    <Border Margin="20,0,0,0" Background="#FF1C1C24" CornerRadius="8"
                            BorderBrush="#FF2A2A34" BorderThickness="1" Padding="6,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="MODEL" FontFamily="{StaticResource Montserrat}"
                                       FontSize="11" FontWeight="Bold" Foreground="#FF6E6E76"
                                       VerticalAlignment="Center" Margin="6,0,10,0"/>
                            <ToggleButton x:Name="BtnModel1" Content="Model 1"
                                          Style="{StaticResource ModelToggle}"
                                          Checked="Model1_Click" Margin="0,4,6,4"/>
                            <ToggleButton x:Name="BtnModel2" Content="Model 2"
                                          Style="{StaticResource ModelToggle}" IsChecked="True"
                                          Checked="Model2_Click" Margin="0,4,6,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Batch Verdict Banner -->
                <Border x:Name="VerdictBorder" Height="84" CornerRadius="12"
                        Background="#FF1C1C24" Margin="0,0,0,14"
                        BorderBrush="#FF2A2A34" BorderThickness="1">
                    <TextBlock x:Name="VerdictText" Text=""
                               FontFamily="{StaticResource Orbitron}"
                               Foreground="White" FontSize="42" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="FailReasonsText" Text=""
                           FontFamily="{StaticResource Montserrat}"
                           Foreground="#FFEF5350" FontSize="13" Margin="0,0,0,6"
                           TextWrapping="Wrap"/>

                <!-- Metric Results (from frame 1) -->
                <Border Background="#FF18181E" CornerRadius="10" Padding="14,12" Margin="0,0,0,14"
                        BorderBrush="#FF2A2A34" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GEOMETRIC METRICS (CAM 1)"
                                   FontFamily="{StaticResource Montserrat}"
                                   Foreground="#FF6E6E76" FontSize="11" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Metric"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="Value"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Min"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="Max"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="Status"
                                       FontFamily="{StaticResource Montserrat}"
                                       Foreground="#FF505058" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#FF2A2A34" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="MetricsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontFamily="{StaticResource ShareTechMono}"
                                                   Foreground="#FFC8C8CD" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ValueText}"
                                                   FontFamily="{StaticResource ShareTechMono}"
                                                   Foreground="{Binding ValueColor}" FontSize="13"
                                                   FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LoText}"
                                                   FontFamily="{StaticResource ShareTechMono}"
                                                   Foreground="#FF6E6E76" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding HiText}"
                                                   FontFamily="{StaticResource ShareTechMono}"
                                                   Foreground="#FF6E6E76" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding StatusText}"
                                                   FontFamily="{StaticResource ShareTechMono}"
                                                   Foreground="{Binding StatusColor}" FontSize="13"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#FF18181E" CornerRadius="10" Padding="14,12" Margin="0,0,0,14"
                        BorderBrush="#FF2A2A34" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="DEFECT DETECTION (MASK R-CNN)"
                                   FontFamily="{StaticResource Montserrat}"
                                   Foreground="#FF6E6E76" FontSize="11" FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="DefectInfoText" Text="---"
                                   FontFamily="{StaticResource ShareTechMono}"
                                   Foreground="#FFC8C8CD" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Batch Timing -->
                <TextBlock x:Name="CycleTimeText" Text=""
                           FontFamily="{StaticResource ShareTechMono}"
                           Foreground="#FF64B5F6" FontSize="12" Margin="0,0,0,6"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="DetailsText" Text=""
                           FontFamily="{StaticResource Montserrat}"
                           Foreground="#FF505058" FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
