<Window x:Class="RoboViz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoboViz"
        mc:Ignorable="d"
        Title="RoboViz – O-Ring Inspection" Height="880" Width="1500"
        Background="#FF1A1A1E" Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*" MinWidth="520"/>
        </Grid.ColumnDefinitions>

        <!-- Image Display -->
        <Border Grid.Column="0" Background="#FF202026" CornerRadius="8" Margin="0,0,16,0">
            <Image x:Name="ImageDisplay" Stretch="Uniform" Margin="8"/>
        </Border>

        <!-- Right Panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Model Status -->
                <TextBlock x:Name="StatusText" Text="Model: loading..."
                           Foreground="#FFC8C8CD" FontSize="13" Margin="0,0,0,8"/>

                <!-- Model Selector + Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Load Image" Width="120" Height="36"
                            Click="LoadImage_Click"
                            Background="#FF388E3C" Foreground="White"
                            FontSize="14" FontWeight="SemiBold"/>
                    <Button x:Name="BtnAnalyze" Content="Analyze" Width="120" Height="36"
                            Click="Analyze_Click" Margin="8,0,0,0"
                            Background="#FF2196F3" Foreground="White"
                            FontSize="14" FontWeight="SemiBold" IsEnabled="False"/>
                    <Border Background="#FF303038" CornerRadius="4" Margin="16,0,0,0"
                            Padding="4,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Model:" Foreground="#FF9E9E9E" FontSize="13"
                                       VerticalAlignment="Center" Margin="4,0,6,0"/>
                            <RadioButton x:Name="RbModel1" Content="Model 1"
                                         GroupName="Model" Foreground="#FFC8C8CD" FontSize="13"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Checked="Model_Checked"/>
                            <RadioButton x:Name="RbModel2" Content="Model 2"
                                         GroupName="Model" Foreground="#FFC8C8CD" FontSize="13"
                                         VerticalAlignment="Center" IsChecked="True"
                                         Checked="Model_Checked"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Verdict Banner -->
                <Border x:Name="VerdictBorder" Height="80" CornerRadius="10"
                        Background="#FF373740" Margin="0,0,0,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="VerdictText" Text="AWAITING"
                                   Foreground="White" FontSize="40" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Fail Reasons -->
                <TextBlock x:Name="FailReasonsText" Text=""
                           Foreground="#FFEF5350" FontSize="13" Margin="0,0,0,6"
                           TextWrapping="Wrap"/>

                <!-- Metric Results Table -->
                <Border Background="#FF252530" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Geometric Metrics" Foreground="#FF8E8E96"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <!-- Header -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Metric" Foreground="#FF6E6E76"
                                       FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Value" Foreground="#FF6E6E76"
                                       FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Lo" Foreground="#FF6E6E76"
                                       FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Hi" Foreground="#FF6E6E76"
                                       FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Status" Foreground="#FF6E6E76"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                        <ItemsControl x:Name="MetricsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Foreground="#FFC8C8CD" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ValueText}"
                                                   Foreground="{Binding ValueColor}" FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LoText}"
                                                   Foreground="#FF7E7E86" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding HiText}"
                                                   Foreground="#FF7E7E86" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding StatusText}"
                                                   Foreground="{Binding StatusColor}" FontSize="13"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Defect Detection Info -->
                <Border Background="#FF252530" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Defect Detection (Mask R-CNN)" Foreground="#FF8E8E96"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DefectInfoText" Text="—"
                                   Foreground="#FFC8C8CD" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Cycle Time -->
                <TextBlock x:Name="CycleTimeText" Text=""
                           Foreground="#FF8CC8FF" FontSize="12" Margin="0,0,0,6"
                           TextWrapping="Wrap"/>

                <!-- File Info -->
                <TextBlock x:Name="DetailsText" Text=""
                           Foreground="#FF6E6E76" FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
